# ─── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=change-me-in-production-use-secrets-generate-key
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=5000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://dataharvest:password@localhost:5432/dataharvest
MONGODB_URL=mongodb://localhost:27017/dataharvest
REDIS_URL=redis://localhost:6379/0
ELASTICSEARCH_URL=http://localhost:9200
CLICKHOUSE_URL=clickhouse://localhost:9000/dataharvest

# ─── Celery ───────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_WORKER_CONCURRENCY=4
CELERY_TASK_SERIALIZER=json
FLOWER_PORT=5555

# ─── BigQuery / Google Cloud ──────────────────────────────────────────────────
GCP_PROJECT_ID=
GCP_CREDENTIALS_PATH=./credentials/gcp-service-account.json
BIGQUERY_DATASET=dataharvest_raw
GCS_BUCKET=dataharvest-storage

# ─── AWS ──────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=dataharvest-exports

# ─── Scraping ─────────────────────────────────────────────────────────────────
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT=30000
SELENIUM_HEADLESS=true
SELENIUM_DRIVER=chromium
DEFAULT_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36
REQUEST_TIMEOUT=30
REQUEST_RETRIES=3
MAX_CONCURRENT_SCRAPERS=10
PROXY_LIST_PATH=./config/proxies.txt
TOR_PROXY=socks5://127.0.0.1:9050
USE_TOR=false

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_DEFAULT=100 per hour
RATE_LIMIT_SCRAPER=20 per minute
RATE_LIMIT_EXPORT=10 per minute

# ─── AI / ML ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
HUGGINGFACE_TOKEN=
MLFLOW_TRACKING_URI=http://localhost:5001
MODEL_CACHE_DIR=./data/models
MAX_PREDICTION_ROWS=100000

# ─── Storage ──────────────────────────────────────────────────────────────────
EXPORT_DIR=./exports
DATA_DIR=./data
LOGS_DIR=./logs
UPLOADS_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=500

# ─── Cache ────────────────────────────────────────────────────────────────────
CACHE_TYPE=redis
CACHE_DEFAULT_TIMEOUT=300
CACHE_KEY_PREFIX=dh:

# ─── Monitoring ───────────────────────────────────────────────────────────────
SENTRY_DSN=
PROMETHEUS_PORT=9090
ENABLE_METRICS=true
LOG_LEVEL=INFO

# ─── WebSocket ───────────────────────────────────────────────────────────────
SOCKETIO_ASYNC_MODE=threading
SOCKETIO_CORS_ALLOWED_ORIGINS=*
SOCKETIO_PING_INTERVAL=25
SOCKETIO_PING_TIMEOUT=60

# ─── JWT Auth ────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-jwt-secret
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=604800
